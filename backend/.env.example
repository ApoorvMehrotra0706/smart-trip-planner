# Turso database
TURSO_URL=libsql://your-db.turso.io
TURSO_TOKEN=your-turso-token

# AI backend (use one of: Groq or Ollama)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (local fallback)
# OLLAMA_URL=http://localhost:11434/api/generate
# OLLAMA_MODEL=llama3.2

# Comma-separated allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-app.vercel.app

# JWT signing secret — generate with: openssl rand -base64 32
# Must match JWT_SECRET set in Vercel frontend env vars
JWT_SECRET=your-jwt-secret-here
